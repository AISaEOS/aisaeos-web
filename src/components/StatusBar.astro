---
interface Props {
	legalLabel: string;
}
const { legalLabel } = Astro.props;
---
<footer class="statusbar">
	<div class="statusbar-status">
		<span class="status-clock">--:--:--</span>
		<span>V001</span>
	</div>
	<div class="statusbar-lang">
		<button type="button" data-lang="en" aria-pressed="true">EN</button>
		<button type="button" data-lang="de" aria-pressed="false">DE</button>
		<button type="button" data-lang="fi" aria-pressed="false">FI</button>
	</div>
	<button type="button" data-action="legal" class="legal-line" aria-label={legalLabel}><span>AISaEOS Oy · Y-tunnus 3412141-7</span></button>
</footer>
